{
  "$schema": "https://opencode.ai/config.json",
  "theme": "system",
  "plugin": ["opencode-gemini-auth@latest"],
  "mcp": {
    "grafana-echsenclub": {
      "type": "local",
      "command": [ "mcp-grafana" ],
      "enabled": false,
      "environment": {
        "GRAFANA_URL": "https://grafana.echsen.club",
        "GRAFANA_API_KEY": "{file:/run/secrets/grafana-service-account}"
      }
    }
  }
}
